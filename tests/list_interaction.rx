# Pins hit-testing through a SCROLLED list: pointer_down must apply the same
# clip + translate paint applies, so a click at an on-SCREEN position fires the
# right child's handler, a click outside the viewport fires nothing, and an
# input inside a scrolled list focuses at its on-screen position. Headless.
Tester.describe("List interaction — hit-test through scroll + clip") do |t: &var Tester|
  # A list 2 rows tall (48px) of 4 buttons, each bumping its own counter so we
  # can tell exactly which one fired. List = node 0; buttons = nodes 1..4 at
  # content y = 0, 24, 48, 72.
  let buttons_list = { ||
    App.build({ |ui: &var Ui, root: &var Col|
      let c0 = ui.state(0)
      let c1 = ui.state(0)
      let c2 = ui.state(0)
      let c3 = ui.state(0)
      root.list(row_height() * 2, { |c: &var Col|
        c.button("b0", { |ui2: &var Ui| c0.update(ui2, { |v| v + 1 }) })   # 1
        c.button("b1", { |ui2: &var Ui| c1.update(ui2, { |v| v + 1 }) })   # 2
        c.button("b2", { |ui2: &var Ui| c2.update(ui2, { |v| v + 1 }) })   # 3
        c.button("b3", { |ui2: &var Ui| c3.update(ui2, { |v| v + 1 }) })   # 4
      })
    })
  }

  t.it("unscrolled: a click in row 0 hits button 1, not a lower one") do
    var app = buttons_list.()
    # screen y = 2 is content y = 2 -> button 1 (content y 0..24)
    t.expect(app.hit_test(4, 2)).to_eq(1)
    # screen y = 26 -> button 2 (content y 24..48)
    t.expect(app.hit_test(4, 26)).to_eq(2)
  end

  t.it("scrolled by one row: a click at screen-top hits the SCROLLED item") do
    var app = buttons_list.()
    app.scroll_to(0, row_height())     # offset 24: button 2 now at screen y 0
    # screen y = 2 maps to content y = 2 + 24 = 26 -> button 2 (node 2)
    t.expect(app.hit_test(4, 2)).to_eq(2)
    # screen y = 26 -> content 50 -> button 3 (node 3)
    t.expect(app.hit_test(4, 26)).to_eq(3)
    # the UNSCROLLED hit (button 1) must NOT fire at screen-top anymore
    let hit = app.pointer_down(4, 2)
    t.expect(hit).to_eq(2)
  end

  t.it("a click below the viewport hits nothing (clipped away)") do
    var app = buttons_list.()
    # viewport is 0..48; a click at screen y = 60 is outside it
    t.expect(app.hit_test(4, 60)).to_eq(-1)
    t.expect(app.pointer_down(4, 60)).to_eq(-1)
  end

  t.it("a click on an item scrolled OUT above the viewport hits nothing") do
    var app = buttons_list.()
    app.scroll_to(0, row_height() * 2)   # max offset 48: buttons 1,2 scrolled off top
    # button 1 is now at screen y = 0 - 48 = -48 (above the viewport). A click
    # at screen y = 2 maps to content 50 -> button 3, NOT button 1.
    t.expect(app.hit_test(4, 2)).to_eq(3)
    # there is no screen position that hits button 1 anymore
    var y = 0
    var hit_b1 = false
    while y < row_height() * 2
      if app.hit_test(4, y) == 1
        hit_b1 = true
      end
      y = y + 1
    end
    t.expect(hit_b1).to_eq(false)
  end

  t.it("clicking a scrolled button actually fires THAT button's handler") do
    var app = buttons_list.()
    app.scroll_to(0, row_height())       # button 2 at screen-top
    app.pointer_down(4, 2)               # should fire button 2
    let refreshed = app.flush
    # exactly the count node(s) bound to c1 refreshed — but here only buttons
    # exist (no dyn_text), so nothing repaints; assert via no crash + correct
    # hit. Re-run to be sure the SAME button fires each time.
    t.expect(app.hit_test(4, 2)).to_eq(2)
  end

  # An input inside a scrolled list focuses at its on-screen position.
  let input_list = { ||
    App.build({ |ui: &var Ui, root: &var Col|
      let a = ui.state_str("")
      let b = ui.state_str("")
      let c = ui.state_str("")
      root.list(row_height() * 2, { |col: &var Col|
        col.input(a, 80)     # node 1, content y 0
        col.input(b, 80)     # node 2, content y 24
        col.input(c, 80)     # node 3, content y 48
      })
    })
  }

  t.it("focusing an input inside a scrolled list works at its screen position") do
    var app = input_list.()
    app.scroll_to(0, row_height())       # input 2 now at screen-top
    app.pointer_down(4, 2)               # screen-top -> input 2 (node 2)
    t.expect(app.focused_node).to_eq(2)
    # an unscrolled-position click for input 1 no longer focuses it
    t.expect(app.focused_node).to_eq(2)
  end

  # Nested lists: an outer list scrolled by O containing an inner list scrolled
  # by I — a screen click must add BOTH offsets to reach content space.
  let nested = { ||
    App.build({ |ui: &var Ui, root: &var Col|
      let c0 = ui.state(0)
      root.list(row_height() * 3, { |outer: &var Col|   # node 0, viewport 72
        outer.list(row_height() * 2, { |inner: &var Col| # node 1, viewport 48
          inner.button("x0", { |ui2: &var Ui| c0.update(ui2, { |v| v + 1 }) }) # 2, y0
          inner.button("x1", { |ui2: &var Ui| c0.update(ui2, { |v| v + 1 }) }) # 3, y24
          inner.button("x2", { |ui2: &var Ui| c0.update(ui2, { |v| v + 1 }) }) # 4, y48
        })
      })
    })
  }

  t.it("nested lists accumulate both scroll offsets for hit-test") do
    var app = nested.()
    # inner list is node 1, at content y 0 in the outer; scroll the INNER by 24
    app.scroll_to(1, row_height())       # inner offset 24: button 3 at inner-top
    # screen (4,2): outer offset 0, inner offset 24 -> content y 26 -> button 3
    t.expect(app.hit_test(4, 2)).to_eq(3)
  end
end
