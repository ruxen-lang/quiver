# The integration test for the L2 core slice: the counter app end-to-end,
# headless. This is the milestone-1 demo from docs/ROADMAP.md — tap the
# button, the number increments, ONLY the count node repaints.
Tester.describe("counter — the vertical slice, end to end") do |t: &var Tester|
  let counter_app = { ||
    App.build({ |ui: &var Ui, root: &var Col|
      let count = ui.state(0)
      root.text("Counter")
      root.dyn_text({ |ui2: &var Ui| "count: #{count.get(ui2)}" })
      root.button("tap", { |ui2: &var Ui| count.update(ui2, { |c| c + 1 }) })
    })
  }

  t.it("first frame paints the whole tree") do
    var app = counter_app.()
    var surface = RecordingSurface.new
    first_frame(&app, &var surface)
    t.expect(surface.size).to_eq(5)
  end

  t.it("tap -> increment -> ONLY the count node repaints") do
    var app = counter_app.()
    var surface = RecordingSurface.new
    first_frame(&app, &var surface)

    # tap the button (third row)
    app.pointer_down(2, row_height() * 2 + 2)
    let repainted = frame(&var app, &var surface)

    t.expect(repainted).to_eq(1)
    t.expect(app.text_of(1)).to_eq("count: 1")
    # last command repainted the count node's new text
    t.expect(surface.command_at(surface.size - 1)).to_eq("text('count: 1',4,40)")
  end

  t.it("idle frames repaint nothing") do
    var app = counter_app.()
    var surface = RecordingSurface.new
    first_frame(&app, &var surface)
    t.expect(frame(&var app, &var surface)).to_eq(0)
    t.expect(surface.size).to_eq(5)
  end

  t.it("ten taps count to ten, one repaint per frame") do
    var app = counter_app.()
    var surface = RecordingSurface.new
    first_frame(&app, &var surface)
    var taps = 0
    while taps < 10
      app.pointer_down(2, row_height() * 2 + 2)
      t.expect(frame(&var app, &var surface)).to_eq(1)
      taps = taps + 1
    end
    t.expect(app.text_of(1)).to_eq("count: 10")
  end

  t.it("clicks on static text never dirty anything") do
    var app = counter_app.()
    var surface = RecordingSurface.new
    first_frame(&app, &var surface)
    app.pointer_down(2, 2)            # "Counter" row
    app.pointer_down(2, row_height() + 2)  # count row
    t.expect(frame(&var app, &var surface)).to_eq(0)
  end
end
