# Pins the vertically-scrolling List (docs/DSL.md): a container with a FIXED
# viewport height that clips its children and scrolls them by an offset.
# All headless — asserted against RecordingSurface, no canvas needed.
Tester.describe("List — fixed viewport, clip + scroll") do |t: &var Tester|
  # A list 2 rows tall (48px) holding 4 single-line texts (each 24px tall,
  # content height 96). The list is node 0; children are nodes 1..4.
  let four_item_list = { ||
    App.build({ |ui: &var Ui, root: &var Col|
      root.list(row_height() * 2, { |c: &var Col|
        c.text("a")     # node 1, y = 0
        c.text("b")     # node 2, y = 24
        c.text("c")     # node 3, y = 48 (just below viewport)
        c.text("d")     # node 4, y = 72
      })
    })
  }

  t.it("the list box is its fixed viewport height, not the content height") do
    var app = four_item_list.()
    t.expect(app.x_of(0)).to_eq(0)
    t.expect(app.y_of(0)).to_eq(0)
    # viewport = 2 rows, even though content is 4 rows tall
    t.expect(app.h_of(0)).to_eq(row_height() * 2)
    # content height is tracked for clamping
    t.expect(app.content_height_of(0)).to_eq(row_height() * 4)
  end

  t.it("children stack on Y in content space (offset-free)") do
    var app = four_item_list.()
    t.expect(app.y_of(1)).to_eq(0)
    t.expect(app.y_of(2)).to_eq(row_height())
    t.expect(app.y_of(3)).to_eq(row_height() * 2)   # first row off-viewport
    t.expect(app.y_of(4)).to_eq(row_height() * 3)
  end

  t.it("scroll_by records the offset; children stay in content space") do
    var app = four_item_list.()
    app.scroll_by(0, row_height())          # scroll down one row
    t.expect(app.scroll_of(0)).to_eq(row_height())
    # geometry is content-space; the offset is applied at paint via translate,
    # so the on-screen position is y_of(child) - scroll_of(list)
    t.expect(app.y_of(1)).to_eq(0)
    t.expect(app.y_of(2)).to_eq(row_height())
    t.expect(app.y_of(1) - app.scroll_of(0)).to_eq(0 - row_height())  # 'a' above
  end

  t.it("scroll offset clamps to [0, content - viewport]") do
    var app = four_item_list.()
    # max = content(96) - viewport(48) = 48
    app.scroll_by(0, 1000)
    t.expect(app.scroll_of(0)).to_eq(row_height() * 2)
    # cannot scroll past the top
    app.scroll_by(0, -1000)
    t.expect(app.scroll_of(0)).to_eq(0)
    # scroll_to clamps too
    app.scroll_to(0, 999)
    t.expect(app.scroll_of(0)).to_eq(row_height() * 2)
  end

  t.it("paint clips to the viewport, translates by -offset, then restores") do
    var app = four_item_list.()
    app.scroll_to(0, row_height())          # offset = 24
    var surface = RecordingSurface.new
    paint_all(&app, &var surface)
    # clear, save, clip(viewport), translate(0,-24), 4 child texts, restore
    t.expect(surface.command_at(0)).to_eq(String.from("clear(255,255,255)"))
    t.expect(surface.command_at(1)).to_eq(String.from("save"))
    t.expect(surface.command_at(2)).to_eq(String.from("clip(0,0,#{app.w_of(0)},#{row_height() * 2})"))
    t.expect(surface.command_at(3)).to_eq(String.from("translate(0,#{0 - row_height()})"))
    # children paint at their CONTENT-space positions (the translate scrolls
    # them); 'a' is the first child, baseline at content y=0 + baseline_drop
    t.expect(surface.command_at(4)).to_eq(String.from("text('a',4,#{baseline_drop()})"))
    # the last command restores the clip/translate
    t.expect(surface.command_at(surface.size - 1)).to_eq(String.from("restore"))
  end

  t.it("structured clip/translate/restore ops are recorded for replay") do
    var app = four_item_list.()
    var surface = RecordingSurface.new
    paint_all(&app, &var surface)
    t.expect(surface.op_at(1)).to_eq(op_save())
    t.expect(surface.op_at(2)).to_eq(op_clip())
    t.expect(surface.w_at(2)).to_eq(app.w_of(0))
    t.expect(surface.h_at(2)).to_eq(row_height() * 2)
    t.expect(surface.op_at(3)).to_eq(op_translate())
    t.expect(surface.y_at(3)).to_eq(0)              # offset 0 at rest
    t.expect(surface.op_at(surface.size - 1)).to_eq(op_restore())
  end
end
